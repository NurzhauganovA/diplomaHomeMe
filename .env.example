# HomeMe CRM — переменные окружения
# cp .env.example .env && nano .env

# ── Django ────────────────────────────────────────────
# python3 -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=ЗАМЕНИ_НА_ДЛИННЫЙ_КЛЮЧ

DEBUG=False

ALLOWED_HOSTS=sushizza.kz,www.sushizza.kz,localhost,127.0.0.1

# ── Database (SQLite) ─────────────────────────────────
# Путь внутри Docker контейнера (постоянный volume)
DB_PATH=/app/data/db.sqlite3

# ── App ───────────────────────────────────────────────
SITE_DOMAIN=sushizza.kz
APP_PORT=8082
